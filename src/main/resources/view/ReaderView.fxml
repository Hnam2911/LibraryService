<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="800.0" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.library.controller.ReaderController">
   <children>
      <Label prefHeight="35.0" prefWidth="260.0" text="Quản lý người dùng">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <TextField fx:id="txtSearch" prefWidth="400.0" promptText="tìm kiếm người dùng theo tên, sđt hoặc email,..." />
         </children>
      </HBox>
      <TableView fx:id="tableReader" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colSTT" prefWidth="44.0" text="STT" />
          <TableColumn fx:id="colName" prefWidth="196.80005645751953" text="Họ và tên" />
            <TableColumn fx:id="colPhone" prefWidth="151.20001220703125" text="Số điện thoại" />
            <TableColumn fx:id="colEmail" prefWidth="179.19992065429688" text="Email" />
            <TableColumn fx:id="colBorrowed" prefWidth="87.99993896484375" text=" Đang mượn" />
        </columns>
      </TableView>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
         <children>
            <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#onAddReader" prefHeight="20.0" prefWidth="70.0" styleClass="accent" text="Thêm" />
            <Button fx:id="btnUpdate" mnemonicParsing="false" onAction="#onUpdateReader" prefHeight="20.0" prefWidth="70.0" text="Sửa" />
            <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#onDeleteReader" prefHeight="20.0" prefWidth="70.0" styleClass="danger" text="Xóa" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnExcel" mnemonicParsing="false" onAction="#onExportExcel" prefHeight="26.0" prefWidth="145.0" styleClass="accent" text="Xuất File Excel" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
